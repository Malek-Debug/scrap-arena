// ---------------------------------------------------------------------------
// AudioManager — Procedural Web Audio synthesis for SCRAP ARENA
// Singleton. All sounds are synthesized on-demand (no external files).
// ---------------------------------------------------------------------------

export class AudioManager {
  private static _instance: AudioManager;
  private ctx: AudioContext | null = null;
  private masterGain!: GainNode;
  private muted = false;

  // Rhythm scheduling
  private _rhythmRunning = false;
  private _beatTimeout: ReturnType<typeof setTimeout> | null = null;
  private _arpIdx: { foundry: number; circuit: number } = { foundry: 0, circuit: 0 };
  private _nextEventTimes: { [key: string]: number } = {};

  // Boss music
  private _bossMusicGain: GainNode | null = null;
  private _bossMusicNodes: AudioNode[] = [];
  private _bossRhythmRunning = false;
  private _bossRhythmTimeout: ReturnType<typeof setTimeout> | null = null;
  private _bossArpIdx = 0;
  private _bossNextTimes: { [key: string]: number } = {};

  // Title music
  private _titleMusicGain: GainNode | null = null;
  private _titleMusicNodes: AudioNode[] = [];

  static get instance(): AudioManager {
    if (!AudioManager._instance) {
      AudioManager._instance = new AudioManager();
    }
    return AudioManager._instance;
  }

  /** Call once on a user gesture (click / key) to unlock AudioContext. */
  init(): void {
    if (this.ctx) return;
    try {
      this.ctx = new AudioContext();
      this.masterGain = this.ctx.createGain();
      this.masterGain.gain.value = 0.3;
      this.masterGain.connect(this.ctx.destination);
    } catch {
      // AudioContext unavailable — all sound methods become no-ops
      this.ctx = null;
    }
  }

  // -----------------------------------------------------------------------
  // Helpers
  // -----------------------------------------------------------------------

  private get now(): number {
    return this.ctx!.currentTime;
  }

  /** Create a short buffer of white noise. */
  private noiseBuffer(durationSec: number): AudioBuffer {
    const ctx = this.ctx!;
    const len = Math.ceil(ctx.sampleRate * durationSec);
    const buf = ctx.createBuffer(1, len, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < len; i++) data[i] = Math.random() * 2 - 1;
    return buf;
  }

  // -----------------------------------------------------------------------
  // Sound effects
  // -----------------------------------------------------------------------

  /** Punchy laser shot — dual-layer sawtooth sweep + sub-bass punch */
  shoot(): void {
    if (!this.ctx) return;
    const t = this.now;

    // Main laser sweep 900→150 Hz
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = "sawtooth";
    osc.frequency.setValueAtTime(900, t);
    osc.frequency.exponentialRampToValueAtTime(150, t + 0.09);
    gain.gain.setValueAtTime(0.35, t);
    gain.gain.linearRampToValueAtTime(0, t + 0.09);
    osc.connect(gain).connect(this.masterGain);
    osc.start(t);
    osc.stop(t + 0.09);

    // Sub-bass punch 60 Hz sine for weight
    const sub = this.ctx.createOscillator();
    const sg = this.ctx.createGain();
    sub.type = "sine";
    sub.frequency.value = 60;
    sg.gain.setValueAtTime(0.25, t);
    sg.gain.linearRampToValueAtTime(0, t + 0.06);
    sub.connect(sg).connect(this.masterGain);
    sub.start(t);
    sub.stop(t + 0.06);

    // High-freq click transient for snap
    const click = this.ctx.createOscillator();
    const cg = this.ctx.createGain();
    click.type = "square";
    click.frequency.value = 2400;
    cg.gain.setValueAtTime(0.15, t);
    cg.gain.linearRampToValueAtTime(0, t + 0.015);
    click.connect(cg).connect(this.masterGain);
    click.start(t);
    click.stop(t + 0.015);
  }

  /** Metallic crunch — noise burst + resonant ping + sub thud */
  hit(): void {
    if (!this.ctx) return;
    const t = this.now;

    // Noise burst — sharp clang
    const noiseSrc = this.ctx.createBufferSource();
    noiseSrc.buffer = this.noiseBuffer(0.04);
    const filter = this.ctx.createBiquadFilter();
    filter.type = "bandpass";
    filter.frequency.value = 3000;
    filter.Q.value = 5;
    const ng = this.ctx.createGain();
    ng.gain.setValueAtTime(0.5, t);
    ng.gain.linearRampToValueAtTime(0, t + 0.04);
    noiseSrc.connect(filter).connect(ng).connect(this.masterGain);
    noiseSrc.start(t);
    noiseSrc.stop(t + 0.04);

    // Metallic ping — high sine with fast decay
    const ping = this.ctx.createOscillator();
    const pg = this.ctx.createGain();
    ping.type = "sine";
    ping.frequency.setValueAtTime(1800, t);
    ping.frequency.exponentialRampToValueAtTime(600, t + 0.08);
    pg.gain.setValueAtTime(0.2, t);
    pg.gain.linearRampToValueAtTime(0, t + 0.08);
    ping.connect(pg).connect(this.masterGain);
    ping.start(t);
    ping.stop(t + 0.08);

    // Sub thud
    const osc = this.ctx.createOscillator();
    const og = this.ctx.createGain();
    osc.type = "sine";
    osc.frequency.value = 120;
    og.gain.setValueAtTime(0.25, t);
    og.gain.linearRampToValueAtTime(0, t + 0.05);
    osc.connect(og).connect(this.masterGain);
    osc.start(t);
    osc.stop(t + 0.05);
  }

  /** Death explosion — white noise decay 200 ms + descending sine 400→80 Hz, 300 ms */
  explosion(): void {
    if (!this.ctx) return;
    const t = this.now;

    // Noise layer
    const noiseSrc = this.ctx.createBufferSource();
    noiseSrc.buffer = this.noiseBuffer(0.25);
    const ng = this.ctx.createGain();
    ng.gain.setValueAtTime(0.6, t);
    ng.gain.exponentialRampToValueAtTime(0.001, t + 0.2);
    noiseSrc.connect(ng).connect(this.masterGain);
    noiseSrc.start(t);
    noiseSrc.stop(t + 0.25);

    // Descending sine
    const osc = this.ctx.createOscillator();
    const og = this.ctx.createGain();
    osc.type = "sine";
    osc.frequency.setValueAtTime(400, t);
    osc.frequency.exponentialRampToValueAtTime(80, t + 0.3);
    og.gain.setValueAtTime(0.4, t);
    og.gain.linearRampToValueAtTime(0, t + 0.3);
    osc.connect(og).connect(this.masterGain);
    osc.start(t);
    osc.stop(t + 0.3);
  }

  /** Whoosh — filtered noise sweep, high→low cutoff, 150 ms */
  dash(): void {
    if (!this.ctx) return;
    const t = this.now;

    const noiseSrc = this.ctx.createBufferSource();
    noiseSrc.buffer = this.noiseBuffer(0.18);
    const filter = this.ctx.createBiquadFilter();
    filter.type = "bandpass";
    filter.frequency.setValueAtTime(4000, t);
    filter.frequency.exponentialRampToValueAtTime(300, t + 0.15);
    filter.Q.value = 2;
    const gain = this.ctx.createGain();
    gain.gain.setValueAtTime(0.5, t);
    gain.gain.linearRampToValueAtTime(0, t + 0.15);
    noiseSrc.connect(filter).connect(gain).connect(this.masterGain);
    noiseSrc.start(t);
    noiseSrc.stop(t + 0.18);
  }

  /** Dimensional shift — two detuned oscillators sweep 200→600→200 Hz, 400 ms + echo */
  worldSwitch(): void {
    if (!this.ctx) return;
    const t = this.now;

    for (const detune of [-15, 15]) {
      const osc = this.ctx.createOscillator();
      const gain = this.ctx.createGain();
      osc.type = "sine";
      osc.detune.value = detune;
      osc.frequency.setValueAtTime(200, t);
      osc.frequency.linearRampToValueAtTime(600, t + 0.2);
      osc.frequency.linearRampToValueAtTime(200, t + 0.4);
      gain.gain.setValueAtTime(0.3, t);
      gain.gain.linearRampToValueAtTime(0, t + 0.4);
      osc.connect(gain).connect(this.masterGain);
      osc.start(t);
      osc.stop(t + 0.4);
    }

    // Reverb-like echo: quiet delayed repeat
    const echo = this.ctx.createOscillator();
    const eg = this.ctx.createGain();
    echo.type = "sine";
    echo.frequency.setValueAtTime(400, t + 0.15);
    echo.frequency.linearRampToValueAtTime(200, t + 0.5);
    eg.gain.setValueAtTime(0, t);
    eg.gain.setValueAtTime(0.1, t + 0.15);
    eg.gain.linearRampToValueAtTime(0, t + 0.5);
    echo.connect(eg).connect(this.masterGain);
    echo.start(t + 0.15);
    echo.stop(t + 0.5);
  }

  /** Coin chime — ascending sine notes C5→E5→G5, 50 ms each */
  pickup(): void {
    if (!this.ctx) return;
    const t = this.now;
    const notes = [523.25, 659.25, 783.99]; // C5, E5, G5

    notes.forEach((freq, i) => {
      const osc = this.ctx!.createOscillator();
      const gain = this.ctx!.createGain();
      osc.type = "sine";
      osc.frequency.value = freq;
      const start = t + i * 0.05;
      gain.gain.setValueAtTime(0.3, start);
      gain.gain.linearRampToValueAtTime(0, start + 0.05);
      osc.connect(gain).connect(this.masterGain);
      osc.start(start);
      osc.stop(start + 0.05);
    });
  }

  /** Player damage — low buzz 100 Hz sawtooth 100 ms + noise */
  playerHit(): void {
    if (!this.ctx) return;
    const t = this.now;

    // Low sawtooth buzz
    const osc = this.ctx.createOscillator();
    const og = this.ctx.createGain();
    osc.type = "sawtooth";
    osc.frequency.value = 100;
    og.gain.setValueAtTime(0.4, t);
    og.gain.linearRampToValueAtTime(0, t + 0.1);
    osc.connect(og).connect(this.masterGain);
    osc.start(t);
    osc.stop(t + 0.1);

    // Noise layer
    const noiseSrc = this.ctx.createBufferSource();
    noiseSrc.buffer = this.noiseBuffer(0.08);
    const ng = this.ctx.createGain();
    ng.gain.setValueAtTime(0.3, t);
    ng.gain.linearRampToValueAtTime(0, t + 0.08);
    noiseSrc.connect(ng).connect(this.masterGain);
    noiseSrc.start(t);
    noiseSrc.stop(t + 0.08);
  }

  // -----------------------------------------------------------------------
  // Background music
  // -----------------------------------------------------------------------

  private musicGain: GainNode | null = null;
  private musicNodes: AudioNode[] = [];

  private _buildTheme(theme: 'foundry' | 'circuit'): { gain: GainNode; nodes: AudioNode[] } {
    const ctx = this.ctx!;
    const nodes: AudioNode[] = [];

    const filter = ctx.createBiquadFilter();
    const gain = ctx.createGain();
    gain.connect(this.masterGain);

    if (theme === 'foundry') {
      filter.type = 'lowpass';
      filter.frequency.value = 400;
      gain.gain.value = 0.1; // center of LFO range 0.05–0.15

      const osc1 = ctx.createOscillator();
      osc1.type = 'sawtooth';
      osc1.frequency.value = 55;
      const g1 = ctx.createGain();
      g1.gain.value = 0.4;
      osc1.connect(g1);
      g1.connect(filter);

      const osc2 = ctx.createOscillator();
      osc2.type = 'sawtooth';
      osc2.frequency.value = 110;
      const g2 = ctx.createGain();
      g2.gain.value = 0.35;
      osc2.connect(g2);
      g2.connect(filter);

      filter.connect(gain);

      const lfo = ctx.createOscillator();
      lfo.type = 'sine';
      lfo.frequency.value = 1.8;
      const lfoDepth = ctx.createGain();
      lfoDepth.gain.value = 0.05; // half of range (0.15−0.05)/2
      lfo.connect(lfoDepth);
      lfoDepth.connect(gain.gain);

      osc1.start(); osc2.start(); lfo.start();
      nodes.push(osc1, g1, osc2, g2, filter, lfo, lfoDepth);
    } else {
      filter.type = 'highpass';
      filter.frequency.value = 300;
      gain.gain.value = 0.13; // center of LFO range 0.08–0.18

      const osc1 = ctx.createOscillator();
      osc1.type = 'square';
      osc1.frequency.value = 220;
      const g1 = ctx.createGain();
      g1.gain.value = 0.6;
      osc1.connect(g1);
      g1.connect(filter);

      const osc2 = ctx.createOscillator();
      osc2.type = 'square';
      osc2.frequency.value = 440;
      const g2 = ctx.createGain();
      g2.gain.value = 0.25;
      osc2.connect(g2);
      g2.connect(filter);

      filter.connect(gain);

      const lfo = ctx.createOscillator();
      lfo.type = 'sine';
      lfo.frequency.value = 7;
      const lfoDepth = ctx.createGain();
      lfoDepth.gain.value = 0.05; // half of range (0.18−0.08)/2
      lfo.connect(lfoDepth);
      lfoDepth.connect(gain.gain);

      osc1.start(); osc2.start(); lfo.start();
      nodes.push(osc1, g1, osc2, g2, filter, lfo, lfoDepth);
    }

    return { gain, nodes };
  }

  private _scheduleRhythm(theme: 'foundry' | 'circuit'): void {
    if (!this._rhythmRunning || !this.ctx) return;
    const ctx = this.ctx;
    const LOOKAHEAD = 0.15;
    const TICK_MS = 50;
    const now = ctx.currentTime;

    if (theme === 'foundry') {
      const melodyNotes = [110, 123.47, 146.83, 164.81, 196];
      if (this._nextEventTimes['f_kick'] === undefined) this._nextEventTimes['f_kick'] = now;
      if (this._nextEventTimes['f_snare'] === undefined) this._nextEventTimes['f_snare'] = now + 0.25;
      if (this._nextEventTimes['f_melody'] === undefined) this._nextEventTimes['f_melody'] = now;

      while (this._nextEventTimes['f_kick'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['f_kick'];
        const src = ctx.createBufferSource();
        src.buffer = this.noiseBuffer(0.08);
        const filt = ctx.createBiquadFilter();
        filt.type = 'bandpass';
        filt.frequency.value = 150;
        filt.Q.value = 1;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0.5, t);
        g.gain.linearRampToValueAtTime(0, t + 0.08);
        src.connect(filt); filt.connect(g); g.connect(this.masterGain);
        src.start(t); src.stop(t + 0.08);
        this._nextEventTimes['f_kick'] += 0.5;
      }

      while (this._nextEventTimes['f_snare'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['f_snare'];
        const src = ctx.createBufferSource();
        src.buffer = this.noiseBuffer(0.06);
        const filt = ctx.createBiquadFilter();
        filt.type = 'bandpass';
        filt.frequency.value = 2000;
        filt.Q.value = 8;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0.4, t);
        g.gain.linearRampToValueAtTime(0, t + 0.06);
        src.connect(filt); filt.connect(g); g.connect(this.masterGain);
        src.start(t); src.stop(t + 0.06);
        this._nextEventTimes['f_snare'] += 1.0;
      }

      while (this._nextEventTimes['f_melody'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['f_melody'];
        const freq = melodyNotes[this._arpIdx.foundry % melodyNotes.length];
        this._arpIdx.foundry++;
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.value = freq;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0, t);
        g.gain.linearRampToValueAtTime(0.3, t + 0.01);
        g.gain.setValueAtTime(0.3, t + 0.16);
        g.gain.linearRampToValueAtTime(0, t + 0.21);
        osc.connect(g); g.connect(this.masterGain);
        osc.start(t); osc.stop(t + 0.21);
        this._nextEventTimes['f_melody'] += 0.4;
      }
    } else {
      const circuitNotes = [220, 261.63, 329.63, 392, 440];
      if (this._nextEventTimes['c_hihat'] === undefined) this._nextEventTimes['c_hihat'] = now;
      if (this._nextEventTimes['c_kick'] === undefined) this._nextEventTimes['c_kick'] = now;
      if (this._nextEventTimes['c_melody'] === undefined) this._nextEventTimes['c_melody'] = now;

      while (this._nextEventTimes['c_hihat'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['c_hihat'];
        const src = ctx.createBufferSource();
        src.buffer = this.noiseBuffer(0.03);
        const filt = ctx.createBiquadFilter();
        filt.type = 'bandpass';
        filt.frequency.value = 8000;
        filt.Q.value = 15;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0.2, t);
        g.gain.linearRampToValueAtTime(0, t + 0.03);
        src.connect(filt); filt.connect(g); g.connect(this.masterGain);
        src.start(t); src.stop(t + 0.03);
        this._nextEventTimes['c_hihat'] += 0.25;
      }

      while (this._nextEventTimes['c_kick'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['c_kick'];
        const osc = ctx.createOscillator();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(80, t);
        osc.frequency.exponentialRampToValueAtTime(30, t + 0.1);
        const g = ctx.createGain();
        g.gain.setValueAtTime(0.4, t);
        g.gain.linearRampToValueAtTime(0, t + 0.1);
        osc.connect(g); g.connect(this.masterGain);
        osc.start(t); osc.stop(t + 0.1);
        this._nextEventTimes['c_kick'] += 0.5;
      }

      while (this._nextEventTimes['c_melody'] < now + LOOKAHEAD) {
        const t = this._nextEventTimes['c_melody'];
        const r = Math.random();
        const noteIdx = r < 0.3 ? 0 : Math.floor(Math.random() * circuitNotes.length);
        const freq = circuitNotes[noteIdx];
        const osc = ctx.createOscillator();
        osc.type = 'square';
        osc.frequency.value = freq;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0, t);
        g.gain.linearRampToValueAtTime(0.15, t + 0.005);
        g.gain.linearRampToValueAtTime(0, t + 0.08);
        osc.connect(g); g.connect(this.masterGain);
        osc.start(t); osc.stop(t + 0.1);
        this._nextEventTimes['c_melody'] += 0.15;
      }
    }

    this._beatTimeout = setTimeout(() => this._scheduleRhythm(theme), TICK_MS);
  }

  private _scheduleBossRhythm(): void {
    if (!this._bossRhythmRunning || !this.ctx) return;
    const ctx = this.ctx;
    const LOOKAHEAD = 0.15;
    const TICK_MS = 50;
    const now = ctx.currentTime;
    const bossNotes = [220, 196, 174.61, 155.56];

    if (this._bossNextTimes['hihat'] === undefined) this._bossNextTimes['hihat'] = now;
    if (this._bossNextTimes['arp'] === undefined) this._bossNextTimes['arp'] = now;

    while (this._bossNextTimes['hihat'] < now + LOOKAHEAD) {
      const t = this._bossNextTimes['hihat'];
      const src = ctx.createBufferSource();
      src.buffer = this.noiseBuffer(0.05);
      const filt = ctx.createBiquadFilter();
      filt.type = 'bandpass';
      filt.frequency.value = 6000;
      filt.Q.value = 8;
      const g = ctx.createGain();
      g.gain.setValueAtTime(0.25, t);
      g.gain.linearRampToValueAtTime(0, t + 0.05);
      src.connect(filt); filt.connect(g); g.connect(this.masterGain);
      src.start(t); src.stop(t + 0.05);
      this._bossNextTimes['hihat'] += 0.18;
    }

    while (this._bossNextTimes['arp'] < now + LOOKAHEAD) {
      const t = this._bossNextTimes['arp'];
      const freq = bossNotes[this._bossArpIdx % bossNotes.length];
      this._bossArpIdx++;
      const osc = ctx.createOscillator();
      osc.type = 'sawtooth';
      osc.frequency.value = freq;
      const g = ctx.createGain();
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.25, t + 0.01);
      g.gain.setValueAtTime(0.2, t + 0.25);
      g.gain.linearRampToValueAtTime(0, t + 0.3);
      osc.connect(g); g.connect(this.masterGain);
      osc.start(t); osc.stop(t + 0.3);
      this._bossNextTimes['arp'] += 0.3;
    }

    this._bossRhythmTimeout = setTimeout(() => this._scheduleBossRhythm(), TICK_MS);
  }

  startMusic(theme: 'foundry' | 'circuit'): void {
    if (!this.ctx) return;
    if (this.musicGain) this.stopMusic();

    const { gain, nodes } = this._buildTheme(theme);
    this.musicGain = gain;
    this.musicNodes = nodes;

    const target = theme === 'foundry' ? 0.1 : 0.13;
    const t = this.ctx.currentTime;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(target, t + 1.0);

    this._rhythmRunning = true;
    this._nextEventTimes = {};
    this._arpIdx = { foundry: 0, circuit: 0 };
    this._scheduleRhythm(theme);
  }

  stopMusic(): void {
    if (!this.ctx || !this.musicGain) return;

    this._rhythmRunning = false;
    if (this._beatTimeout !== null) {
      clearTimeout(this._beatTimeout);
      this._beatTimeout = null;
    }
    this._nextEventTimes = {};

    const t = this.ctx.currentTime;
    const gain = this.musicGain;
    const nodes = this.musicNodes;

    gain.gain.cancelScheduledValues(t);
    gain.gain.setValueAtTime(gain.gain.value, t);
    gain.gain.linearRampToValueAtTime(0, t + 0.8);

    this.musicGain = null;
    this.musicNodes = [];

    setTimeout(() => {
      nodes.forEach(n => {
        if (n instanceof OscillatorNode) {
          try { n.stop(); } catch { /* already stopped */ }
        }
        try { n.disconnect(); } catch { /* already disconnected */ }
      });
      try { gain.disconnect(); } catch { /* already disconnected */ }
    }, 900);
  }

  crossfadeToTheme(theme: 'foundry' | 'circuit'): void {
    if (!this.ctx) return;

    this._rhythmRunning = false;
    if (this._beatTimeout !== null) {
      clearTimeout(this._beatTimeout);
      this._beatTimeout = null;
    }
    this._nextEventTimes = {};

    const t = this.ctx.currentTime;
    const fadeDuration = 1.5;

    if (this.musicGain) {
      const oldGain = this.musicGain;
      const oldNodes = this.musicNodes;
      oldGain.gain.cancelScheduledValues(t);
      oldGain.gain.setValueAtTime(oldGain.gain.value, t);
      oldGain.gain.linearRampToValueAtTime(0, t + fadeDuration);

      setTimeout(() => {
        oldNodes.forEach(n => {
          if (n instanceof OscillatorNode) {
            try { n.stop(); } catch { /* already stopped */ }
          }
          try { n.disconnect(); } catch { /* already disconnected */ }
        });
        try { oldGain.disconnect(); } catch { /* already disconnected */ }
      }, (fadeDuration + 0.1) * 1000);
    }

    const { gain, nodes } = this._buildTheme(theme);
    this.musicGain = gain;
    this.musicNodes = nodes;

    const target = theme === 'foundry' ? 0.1 : 0.13;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(target, t + fadeDuration);

    this._rhythmRunning = true;
    this._arpIdx = { foundry: 0, circuit: 0 };
    this._scheduleRhythm(theme);
  }

  // -----------------------------------------------------------------------
  // Boss music
  // -----------------------------------------------------------------------

  startBossMusic(): void {
    if (!this.ctx) return;
    this.stopMusic();

    const ctx = this.ctx;
    const nodes: AudioNode[] = [];
    const gain = ctx.createGain();
    gain.gain.value = 0;
    gain.connect(this.masterGain);

    const bassOsc = ctx.createOscillator();
    bassOsc.type = 'sawtooth';
    bassOsc.frequency.value = 55;
    const bassG = ctx.createGain();
    bassG.gain.value = 0.15;
    bassOsc.connect(bassG);
    bassG.connect(gain);
    bassOsc.start();
    nodes.push(bassOsc, bassG);

    this._bossMusicGain = gain;
    this._bossMusicNodes = nodes;

    const t = this.now;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(1.0, t + 1.5);

    this._bossRhythmRunning = true;
    this._bossNextTimes = {};
    this._bossArpIdx = 0;
    this._scheduleBossRhythm();
  }

  stopBossMusic(): void {
    if (!this.ctx || !this._bossMusicGain) return;

    this._bossRhythmRunning = false;
    if (this._bossRhythmTimeout !== null) {
      clearTimeout(this._bossRhythmTimeout);
      this._bossRhythmTimeout = null;
    }

    const t = this.now;
    const gain = this._bossMusicGain;
    const nodes = this._bossMusicNodes;

    gain.gain.cancelScheduledValues(t);
    gain.gain.setValueAtTime(gain.gain.value, t);
    gain.gain.linearRampToValueAtTime(0, t + 1.0);

    this._bossMusicGain = null;
    this._bossMusicNodes = [];

    setTimeout(() => {
      nodes.forEach(n => {
        if (n instanceof OscillatorNode) {
          try { n.stop(); } catch { /* already stopped */ }
        }
        try { n.disconnect(); } catch { /* already disconnected */ }
      });
      try { gain.disconnect(); } catch { /* already disconnected */ }
    }, 1100);
  }

  // -----------------------------------------------------------------------
  // Wave complete jingle
  // -----------------------------------------------------------------------

  waveComplete(): void {
    if (!this.ctx) return;
    const t = this.now;
    const notes = [523.25, 659.25, 783.99, 1046.5];

    notes.forEach((freq, i) => {
      const start = t + i * 0.09;
      const osc = this.ctx!.createOscillator();
      const g = this.ctx!.createGain();
      osc.type = 'sine';
      osc.frequency.value = freq;
      g.gain.setValueAtTime(0, start);
      g.gain.linearRampToValueAtTime(0.3, start + 0.01);
      g.gain.setValueAtTime(0.3, start + 0.08);
      g.gain.linearRampToValueAtTime(0, start + 0.11);
      osc.connect(g); g.connect(this.masterGain);
      osc.start(start); osc.stop(start + 0.12);
    });
  }

  // -----------------------------------------------------------------------
  // Combo hit escalation
  // -----------------------------------------------------------------------

  comboHit(count: number): void {
    if (!this.ctx) return;
    const t = this.now;

    if (count >= 10) {
      [523.25, 659.25, 783.99].forEach(freq => {
        const osc = this.ctx!.createOscillator();
        const g = this.ctx!.createGain();
        osc.type = 'sine';
        osc.frequency.value = freq;
        g.gain.setValueAtTime(0.2, t);
        g.gain.linearRampToValueAtTime(0, t + 0.12);
        osc.connect(g); g.connect(this.masterGain);
        osc.start(t); osc.stop(t + 0.12);
      });
    } else if (count >= 5) {
      [800, 1000].forEach((freq, i) => {
        const start = t + i * 0.06;
        const osc = this.ctx!.createOscillator();
        const g = this.ctx!.createGain();
        osc.type = 'sine';
        osc.frequency.value = freq;
        g.gain.setValueAtTime(0.25, start);
        g.gain.linearRampToValueAtTime(0, start + 0.06);
        osc.connect(g); g.connect(this.masterGain);
        osc.start(start); osc.stop(start + 0.06);
      });
    } else if (count >= 3) {
      const osc = this.ctx.createOscillator();
      const g = this.ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 1200;
      g.gain.setValueAtTime(0.2, t);
      g.gain.linearRampToValueAtTime(0, t + 0.05);
      osc.connect(g); g.connect(this.masterGain);
      osc.start(t); osc.stop(t + 0.05);
    }
  }

  // -----------------------------------------------------------------------
  // Overheat sounds
  // -----------------------------------------------------------------------

  overheatWarning(): void {
    if (!this.ctx) return;
    const t = this.now;

    for (let i = 0; i < 3; i++) {
      const start = t + i * 0.08;
      const osc = this.ctx.createOscillator();
      const g = this.ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 800;
      g.gain.setValueAtTime(0.25, start);
      g.gain.linearRampToValueAtTime(0, start + 0.04);
      osc.connect(g); g.connect(this.masterGain);
      osc.start(start); osc.stop(start + 0.04);
    }
  }

  overheatActive(): void {
    if (!this.ctx) return;
    const t = this.now;

    const osc = this.ctx.createOscillator();
    const g = this.ctx.createGain();
    osc.type = 'sawtooth';
    osc.frequency.value = 600;
    g.gain.setValueAtTime(0.15, t);
    g.gain.linearRampToValueAtTime(0, t + 0.3);
    osc.connect(g); g.connect(this.masterGain);
    osc.start(t); osc.stop(t + 0.3);
  }

  // -----------------------------------------------------------------------
  // Player death
  // -----------------------------------------------------------------------

  playerDeath(): void {
    if (!this.ctx) return;
    const t = this.now;

    const osc = this.ctx.createOscillator();
    const og = this.ctx.createGain();
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(800, t);
    osc.frequency.exponentialRampToValueAtTime(100, t + 0.8);
    og.gain.setValueAtTime(0.4, t);
    og.gain.linearRampToValueAtTime(0, t + 0.8);
    osc.connect(og); og.connect(this.masterGain);
    osc.start(t); osc.stop(t + 0.8);

    const sub = this.ctx.createOscillator();
    const sg = this.ctx.createGain();
    sub.type = 'sine';
    sub.frequency.value = 40;
    sg.gain.setValueAtTime(0.3, t);
    sg.gain.linearRampToValueAtTime(0, t + 0.6);
    sub.connect(sg); sg.connect(this.masterGain);
    sub.start(t); sub.stop(t + 0.6);

    const noiseSrc = this.ctx.createBufferSource();
    noiseSrc.buffer = this.noiseBuffer(0.2);
    const filter = this.ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 300;
    const ng = this.ctx.createGain();
    ng.gain.setValueAtTime(0.35, t);
    ng.gain.linearRampToValueAtTime(0, t + 0.2);
    noiseSrc.connect(filter); filter.connect(ng); ng.connect(this.masterGain);
    noiseSrc.start(t); noiseSrc.stop(t + 0.2);
  }

  // -----------------------------------------------------------------------
  // Title screen music
  // -----------------------------------------------------------------------

  startTitleMusic(): void {
    if (!this.ctx) return;
    if (this._titleMusicGain) this.stopTitleMusic();

    const ctx = this.ctx;
    const nodes: AudioNode[] = [];

    const gain = ctx.createGain();
    gain.gain.value = 0.055;
    gain.connect(this.masterGain);

    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 500;
    filter.connect(gain);

    [130.81, 164.81, 196.00].forEach(freq => {
      const osc = ctx.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = freq;
      const og = ctx.createGain();
      og.gain.value = 0.5;
      osc.connect(og); og.connect(filter);
      osc.start();
      nodes.push(osc, og);
    });

    // LFO on gain: 0.05 Hz, oscillates 0.03–0.08 (center 0.055, depth ±0.025)
    const gainLfo = ctx.createOscillator();
    gainLfo.type = 'sine';
    gainLfo.frequency.value = 0.05;
    const gainLfoDepth = ctx.createGain();
    gainLfoDepth.gain.value = 0.025;
    gainLfo.connect(gainLfoDepth);
    gainLfoDepth.connect(gain.gain);
    gainLfo.start();
    nodes.push(gainLfo, gainLfoDepth);

    // LFO on filter: very slow, sweeps 200–800 Hz (center 500, depth ±300)
    const filterLfo = ctx.createOscillator();
    filterLfo.type = 'sine';
    filterLfo.frequency.value = 0.02;
    const filterLfoDepth = ctx.createGain();
    filterLfoDepth.gain.value = 300;
    filterLfo.connect(filterLfoDepth);
    filterLfoDepth.connect(filter.frequency);
    filterLfo.start();
    nodes.push(filterLfo, filterLfoDepth, filter);

    this._titleMusicGain = gain;
    this._titleMusicNodes = nodes;

    const t = this.now;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(0.055, t + 1.5);
  }

  stopTitleMusic(): void {
    if (!this.ctx || !this._titleMusicGain) return;

    const t = this.now;
    const gain = this._titleMusicGain;
    const nodes = this._titleMusicNodes;

    gain.gain.cancelScheduledValues(t);
    gain.gain.setValueAtTime(gain.gain.value, t);
    gain.gain.linearRampToValueAtTime(0, t + 1.5);

    this._titleMusicGain = null;
    this._titleMusicNodes = [];

    setTimeout(() => {
      nodes.forEach(n => {
        if (n instanceof OscillatorNode) {
          try { n.stop(); } catch { /* already stopped */ }
        }
        try { n.disconnect(); } catch { /* already disconnected */ }
      });
      try { gain.disconnect(); } catch { /* already disconnected */ }
    }, 1600);
  }

  // -----------------------------------------------------------------------
  // Volume control
  // -----------------------------------------------------------------------

  setMute(muted: boolean): void {
    this.muted = muted;
    if (this.masterGain) {
      this.masterGain.gain.value = muted ? 0 : 0.3;
    }
  }

  get isMuted(): boolean {
    return this.muted;
  }
}
